"""
deblur/deblur_model.py
======================
DeepDeblur-PyTorch 的推理封装。
基于: https://github.com/SeungjunNah/DeepDeblur-PyTorch
论文: Deep Multi-scale CNN for Dynamic Scene Deblurring (CVPR 2017)

使用方法:
    model = DeblurModel(checkpoint="weights/deblur/DeepDeblur_GOPRO.pt")
    sharp = model.deblur(blurry_image)   # numpy HxWx3 uint8 → numpy HxWx3 uint8
"""
import sys
import os
import logging
from pathlib import Path
from typing import Union
import cv2
import numpy as np
import torch
import torch.nn as nn
import torch.nn.functional as F

logger = logging.getLogger(__name__)

# ──────────────────────────────────────────────────────────────
# DeepDeblur 网络结构（精确匹配 DeepDeblur_GOPRO.pt 的 checkpoint 格式）
# checkpoint 结构: { 'G': OrderedDict { 'body_models.X.body.Y.*': tensor } }
# 每个 body_model: Conv(6→64,5x5) + N×ResBlock(64,5x5) + Conv(64→3,5x5)
# 输入 6 通道 = 当前尺度图像(3) + 上一尺度输出上采样(3)
# ──────────────────────────────────────────────────────────────

class ResBlock(nn.Module):
    """5x5 残差块，匹配原始 DeepDeblur 权重"""
    def __init__(self, channels: int = 64, kernel_size: int = 5):
        super().__init__()
        pad = kernel_size // 2
        self.body = nn.Sequential(
            nn.Conv2d(channels, channels, kernel_size, 1, pad),
            nn.ReLU(inplace=True),
            nn.Conv2d(channels, channels, kernel_size, 1, pad),
        )

    def forward(self, x):
        return x + self.body(x)


class BodyModel(nn.Module):
    """
    单尺度 body model，对应 checkpoint 中的 body_models.X。
    body.0        : Conv2d(in_channels=6, 64, 5x5)
    body.1..N-1   : ResBlock(64, 5x5)
    body.N        : Conv2d(64, 3, 5x5)  输出残差图像
    """
    def __init__(self, in_channels: int = 6, num_features: int = 64,
                 num_resblocks: int = 8, kernel_size: int = 5):
        super().__init__()
        pad = kernel_size // 2
        layers = [nn.Conv2d(in_channels, num_features, kernel_size, 1, pad)]
        for _ in range(num_resblocks):
            layers.append(ResBlock(num_features, kernel_size))
        layers.append(nn.Conv2d(num_features, 3, kernel_size, 1, pad))
        self.body = nn.Sequential(*layers)

    def forward(self, x):
        return self.body(x)


class DeepDeblurNet(nn.Module):
    """
    Multi-scale DeepDeblur (3 尺度)。
    从最粗粒度到最细粒度逐步去模糊，每尺度以 [图像, 上一输出] 拼接为输入。
    """
    NUM_SCALES = 3

    def __init__(self, num_features: int = 64, num_resblocks: int = 8,
                 kernel_size: int = 5, in_channels_list=None):
        super().__init__()
        # in_channels 由外部传入，各尺度可不同（从 checkpoint 自动推断）
        if in_channels_list is None:
            in_channels_list = [6] * (self.NUM_SCALES - 1) + [3]
        assert len(in_channels_list) == self.NUM_SCALES
        self.body_models = nn.ModuleList([
            BodyModel(ic, num_features, num_resblocks, kernel_size)
            for ic in in_channels_list
        ])

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (B, 3, H, W)，值域 [0, 1]
        Returns:
            (B, 3, H, W)，去模糊结果，值域 [0, 1]
        """
        # 构建图像金字塔：pyramid[0]=最细(原图), pyramid[N-1]=最粗(最小)
        pyramid = [x]
        for _ in range(self.NUM_SCALES - 1):
            pyramid.append(
                F.interpolate(pyramid[-1], scale_factor=0.5,
                              mode='bilinear', align_corners=False)
            )

        # body_models[N-1] 对应最粗尺度，输入通道=3（无前序输出可拼接）
        coarsest = pyramid[self.NUM_SCALES - 1]
        residual = self.body_models[self.NUM_SCALES - 1](coarsest)
        prev_output = torch.clamp(coarsest + residual, 0.0, 1.0)

        # 从次粗到最细，body_models[i] 对应 pyramid[i]，输入通道=6
        for i in range(self.NUM_SCALES - 2, -1, -1):
            img = pyramid[i]
            prev_up = F.interpolate(prev_output, size=img.shape[-2:],
                                    mode='bilinear', align_corners=False)
            inp = torch.cat([img, prev_up], dim=1)   # (B, 6, H, W)
            residual = self.body_models[i](inp)       # (B, 3, H, W)
            prev_output = torch.clamp(img + residual, 0.0, 1.0)

        return prev_output


# ──────────────────────────────────────────────────────────────
# 公共接口
# ──────────────────────────────────────────────────────────────

class DeblurModel:
    """
    去模糊推理接口。
    Args:
        checkpoint: 预训练权重路径 (.pt / .pth)
        device:     'cuda' | 'cpu' | 'auto'
        tile_size:  分块推理的块大小（0 = 不分块，高分辨率图建议 512）
        tile_overlap: 分块重叠像素
    """
    def __init__(
        self,
        checkpoint: str,
        device: str = "auto",
        tile_size: int = 0,
        tile_overlap: int = 32,
    ):
        self.tile_size = tile_size
        self.tile_overlap = tile_overlap

        if device == "auto":
            self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        else:
            self.device = torch.device(device)

        self.model = self._load_model(checkpoint)
        self.model.eval()
        logger.info(f"DeblurModel 已加载: {checkpoint} → 设备: {self.device}")

    def _load_model(self, checkpoint: str) -> nn.Module:
        """加载模型权重，自动适配 checkpoint 中的 num_resblocks。"""
        ckpt = torch.load(checkpoint, map_location="cpu")

        # 解析 state_dict：支持 {'G': OrderedDict} 格式和常规格式
        if "G" in ckpt:
            state_dict = ckpt["G"]
        else:
            state_dict = ckpt.get("state_dict", ckpt.get("model", ckpt))

        # 去除 DataParallel 的 'module.' 前缀
        state_dict = {k.replace("module.", ""): v for k, v in state_dict.items()}

        # 从 checkpoint 自动推断 num_resblocks（body.0=head, body.N=tail, 中间是 ResBlock）
        body0_indices = [
            int(k.split(".")[3])
            for k in state_dict
            if k.startswith("body_models.0.body.") and k.endswith(".weight")
        ]
        if body0_indices:
            max_idx = max(body0_indices)   # tail 的索引
            num_resblocks = max_idx - 1    # head(0) + resblocks(1..max-1) + tail(max)
            logger.info(f"从 checkpoint 检测到 num_resblocks={num_resblocks}")
        else:
            num_resblocks = 8
            logger.warning("无法自动检测 num_resblocks，使用默认值 8")

        # 从 checkpoint 读取每个尺度真实的 in_channels
        in_channels_list = []
        for i in range(3):
            k = f'body_models.{i}.body.0.weight'
            if k in state_dict:
                in_channels_list.append(state_dict[k].shape[1])
            else:
                in_channels_list.append(6)
        logger.info(f"各尺度 in_channels: {in_channels_list}")
        model = DeepDeblurNet(num_resblocks=num_resblocks, in_channels_list=in_channels_list)
        missing, unexpected = model.load_state_dict(state_dict, strict=False)
        if missing:
            logger.warning(f"缺失的 key ({len(missing)}): {missing[:5]} ...")
        if unexpected:
            logger.warning(f"多余的 key ({len(unexpected)}): {unexpected[:5]} ...")

        return model.to(self.device)

    @torch.no_grad()
    def deblur(self, image: np.ndarray) -> np.ndarray:
        """
        对单张图像去模糊。
        Args:
            image: BGR numpy 数组，shape (H, W, 3)，dtype uint8
        Returns:
            sharp: BGR numpy 数组，shape (H, W, 3)，dtype uint8
        """
        rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB).astype(np.float32) / 255.0
        tensor = torch.from_numpy(rgb).permute(2, 0, 1).unsqueeze(0).to(self.device)

        if self.tile_size > 0:
            output = self._tile_infer(tensor)
        else:
            output = self.model(tensor)

        out_np = output.squeeze(0).permute(1, 2, 0).cpu().numpy()
        out_np = np.clip(out_np * 255.0, 0, 255).astype(np.uint8)
        return cv2.cvtColor(out_np, cv2.COLOR_RGB2BGR)

    @torch.no_grad()
    def deblur_batch(self, images: list) -> list:
        """批量去模糊。"""
        return [self.deblur(img) for img in images]

    def _tile_infer(self, tensor: torch.Tensor) -> torch.Tensor:
        """分块推理，避免高分辨率图像显存不足。"""
        B, C, H, W = tensor.shape
        s = self.tile_size
        ov = self.tile_overlap
        output = torch.zeros_like(tensor)
        weight = torch.zeros(B, 1, H, W, device=self.device)

        for y in range(0, H, s - ov):
            for x in range(0, W, s - ov):
                y1, y2 = y, min(y + s, H)
                x1, x2 = x, min(x + s, W)
                tile = tensor[:, :, y1:y2, x1:x2]
                result = self.model(tile)
                output[:, :, y1:y2, x1:x2] += result
                weight[:, :, y1:y2, x1:x2] += 1.0

        return output / weight.clamp(min=1.0)
